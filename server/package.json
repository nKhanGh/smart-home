{
  "name": "smarthome-backend",
  "version": "2.0.0",
  "description": "Smart Home Backend — TypeScript + MongoDB + Adafruit IO",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "sync": "ts-node src/adafruit/syncAdafruit.ts",
    "sync:thresholds": "ts-node src/adafruit/syncAdafruit.ts --threshold-only",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.0",
    "mqtt": "^5.3.4",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
